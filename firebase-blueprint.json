{
  "entities": {
    "Clan": {
      "title": "Clan",
      "description": "Core data for a clan",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Clan name" },
        "level": { "type": "number", "description": "Clan level" },
        "description": { "type": "string", "description": "Clan description" },
        "capacity": { "type": "number", "description": "Max capacity of members" },
        "ownerId": { "type": "string", "description": "UID of the clan owner" },
        "trophyCount": { "type": "number", "description": "Total trophies" },
        "guideImagePost1": { "type": "string", "description": "Main guide image URL" }
      },
      "required": ["name", "level", "ownerId"]
    },
    "Member": {
      "title": "Member",
      "description": "A member of a clan",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Firebase UID" },
        "name": { "type": "string", "description": "Member name" },
        "role": { "type": "string", "enum": ["leader", "co-leader", "elder", "member"] },
        "trophies": { "type": "number", "description": "Individual trophy count" },
        "donations": { "type": "number", "description": "Number of card donations" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "avatarUrl": { "type": "string", "description": "Profile picture URL" },
        "profileBg": { "type": "string", "description": "Profile background image URL or hex" },
        "profileBorder": { "type": "string", "description": "Selected profile border ID" },
        "xp": { "type": "number", "description": "Experience points" },
        "level": { "type": "number", "description": "Member level" },
        "diamonds": { "type": "number", "description": "Diamond currency" },
        "coins": { "type": "number", "description": "Gold coins" },
        "boxes": { "type": "number", "description": "Number of loot boxes" },
        "heroPower": { "type": "number", "description": "Total hero power" },
        "premiumPass": { "type": "boolean", "description": "Whether user has premium pass" },
        "lastDailyBonus": { "type": "string", "description": "ISO date of last bonus claim" },
        "appTheme": { "type": "string", "description": "Selected application theme" },
        "chatTheme": { "type": "string", "description": "Selected chat background theme" },
        "opacityLevel": { "type": "number", "description": "UI opacity percentage" },
        "lastCelebratedLevel": { "type": "number", "description": "Last level up celebrated" },
        "joinedAt": { "type": "string", "description": "ISO join date" },
        "completedMissions": { "type": "array", "items": { "type": "string" }, "description": "List of mission IDs completed" },
        "visitedMissionsBoard": { "type": "boolean", "description": "Whether first time on missions" },
        "updateRewardClaimed": { "type": "boolean", "description": "Whether user claimed the update reward" },
        "title": { "type": "string", "description": "Equipped honor title" },
        "unlockedTitles": { "type": "array", "items": { "type": "string" }, "description": "Unlocked honor titles" },
        "nicknameColor": { "type": "string", "description": "Selected nickname color ID" },
        "unlockedColors": { "type": "array", "items": { "type": "string" }, "description": "Unlocked nickname color IDs" },
        "combatGroup": { "type": "string", "description": "Selected combat group for the tournament" },
        "combatGroupClaimed": { "type": "boolean", "description": "Whether the tournament rewards have been claimed/approved for this member" }
      },
      "required": ["userId", "name", "role", "trophies"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "An announcement message for clan members",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Announcement title" },
        "content": { "type": "string", "description": "Announcement content" },
        "authorId": { "type": "string", "description": "UID of the announcer" },
        "createdAt": { "type": "object", "description": "Server timestamp" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    },
    "WarLog": {
      "title": "WarLog",
      "description": "Log of a clan war",
      "type": "object",
      "properties": {
        "opponent": { "type": "string", "description": "Opponent clan name" },
        "result": { "type": "string", "enum": ["win", "loss", "draw"] },
        "date": { "type": "object", "description": "War date Server timestamp" },
        "scoreSelf": { "type": "number", "description": "Score of our clan" },
        "scoreOpponent": { "type": "number", "description": "Score of the opponent" }
      },
      "required": ["opponent", "result", "date", "scoreSelf", "scoreOpponent"]
    },
    "TheftReport": {
      "title": "TheftReport",
      "description": "A report of theft made by a member",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string", "description": "UID of the reporter" },
        "reporterName": { "type": "string", "description": "Name of the reporter" },
        "timestamp": { "type": "string", "description": "ISO date of the report" }
      },
      "required": ["reporterId", "reporterName", "timestamp"]
    }
  },
  "firestore": {
    "/clans/{clanId}": {
      "schema": "Clan",
      "description": "Global settings and info for a specific clan"
    },
    "/clans/{clanId}/members/{memberId}": {
      "schema": "Member",
      "description": "List of members in a clan"
    },
    "/clans/{clanId}/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Announcements made in a clan"
    },
    "/clans/{clanId}/wars/{warId}": {
      "schema": "WarLog",
      "description": "History of clan wars"
    },
    "/clans/{clanId}/theft_reports/{reportId}": {
      "schema": "TheftReport",
      "description": "Reports of theft available to leaders"
    }
  }
}
