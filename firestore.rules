rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 1. HELPERS & PRIMITIVES
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Auth helpers
    function isClanMember(clanId) {
      return exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid));
    }
    
    function isClanAdmin(clanId) {
      return request.auth.token.email in ['ryankevyn3000@gmail.com', 'ryankevyn2025@gmail.com', 'ryankevyn2020@gmail.com'] || (
        exists(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/clans/$(clanId)/members/$(request.auth.uid)).data.role == 'leader'
      );
    }

    function isBanned() {
      return exists(/databases/$(database)/documents/bans/$(request.auth.uid));
    }

    function isOwner(data) { return data.userId == request.auth.uid; }

    // -------------------------------------------------------------------------
    // 2. ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    
    function isValidClan(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.level is number && data.level >= 1;
    }

    function isValidMember(data) {
      return (data.get('name', '') == null || data.get('name', '') is string) &&
             (data.get('role', 'warrior') == null || data.get('role', 'warrior') in ['leader', 'diplomat', 'military_leader', 'recruiter', 'muse', 'warrior']) &&
             (data.get('trophies', 0) == null || data.get('trophies', 0) is number) &&
             (data.get('xp', 0) == null || data.get('xp', 0) is number) &&
             (data.get('level', 0) == null || data.get('level', 0) is number) &&
             (data.get('completedMissions', []) == null || data.get('completedMissions', []) is list) &&
             (data.get('visitedMissionsBoard', false) == null || data.get('visitedMissionsBoard', false) is bool) &&
             (data.get('userId', '') == null || data.get('userId', '') is string) &&
             (data.get('title', '') == null || data.get('title', '') is string) &&
             (data.get('unlockedTitles', []) == null || data.get('unlockedTitles', []) is list) &&
             (data.get('nicknameColor', '') == null || data.get('nicknameColor', '') is string) &&
             (data.get('unlockedColors', []) == null || data.get('unlockedColors', []) is list) &&
             (data.get('combatGroup', '') == null || data.get('combatGroup', '') is string) &&
             (data.get('combatGroupClaimed', false) == null || data.get('combatGroupClaimed', false) is bool);
    }

    function isValidMemberCreate(data) {
      return isValidMember(data) && 
             data.userId == request.auth.uid &&
             (data.role == 'warrior' || request.auth.token.email in ['ryankevyn3000@gmail.com', 'ryankevyn2025@gmail.com']);
    }

    function isValidAnnouncement(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.authorId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidWarLog(data) {
      return data.opponent is string && data.opponent.size() > 0 &&
             data.result in ['win', 'loss', 'draw'] &&
             data.scoreSelf is number && data.scoreOpponent is number;
    }

    // -------------------------------------------------------------------------
    // 3. MATCH BLOCKS
    // -------------------------------------------------------------------------

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Clans
    match /clans/{clanId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn() && !isBanned() && isValidClan(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && !isBanned() && isValidClan(incoming()) && (
        isClanAdmin(clanId) && 
        incoming().ownerId == existing().ownerId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'level', 'trophyCount', 'capacity', 'guideImagePost1'])
      );
      allow delete: if isSignedIn() && isClanAdmin(clanId) && existing().ownerId == request.auth.uid;

      // Members Subcollection
      match /members/{memberId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && !isBanned() && isValidMemberCreate(incoming());
        allow update: if isSignedIn() && !isBanned() && (
          (request.auth.uid == memberId && incoming().diff(existing()).affectedKeys().hasOnly([
            'status', 'trophies', 'donations', 'avatarUrl', 'name', 
            'heroPower', 'diamonds', 'boxes', 'coins', 'lastDailyBonus', 
            'appTheme', 'chatTheme', 'premiumPass', 'xp', 'level',
            'completedMissions', 'visitedMissionsBoard', 'opacityLevel', 'updateRewardClaimed',
            'lastCelebratedLevel', 'joinedAt', 'userId', 'id', 'profileBorder', 'profileBg',
            'title', 'unlockedTitles', 'nicknameColor', 'unlockedColors', 'combatGroup', 'combatGroupClaimed'
          ]) && isValidMember(incoming())) ||
          isClanAdmin(clanId)
        );
        allow delete: if isSignedIn() && (isOwner(existing()) || isClanAdmin(clanId));
      }

      // Announcements Subcollection
      match /announcements/{announcementId} {
        allow get, list: if isSignedIn() && isClanMember(clanId);
        allow create: if isSignedIn() && isClanAdmin(clanId) && isValidAnnouncement(incoming());
        allow update: if isSignedIn() && isClanAdmin(clanId) && isValidAnnouncement(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content']);
        allow delete: if isSignedIn() && isClanAdmin(clanId);
      }

      // Wars Subcollection
      match /wars/{warId} {
        allow get, list: if isSignedIn() && isClanMember(clanId);
        allow create: if isSignedIn() && isClanAdmin(clanId) && isValidWarLog(incoming());
        allow update: if isSignedIn() && isClanAdmin(clanId) && isValidWarLog(incoming());
        allow delete: if isSignedIn() && isClanAdmin(clanId);
      }

      // Theft Reports Subcollection
      match /theft_reports/{reportId} {
        allow create: if isSignedIn() && isClanMember(clanId);
        allow get, list, delete: if isSignedIn() && isClanAdmin(clanId);
      }
    }

    // Blacklist (Bans)
    match /bans/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isClanAdmin('main-clan');
    }
  }
}
